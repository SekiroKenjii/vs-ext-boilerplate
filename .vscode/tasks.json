{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["watch:esbuild", "watch:tsc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "watch:esbuild",
      "type": "shell",
      "command": "pnpm run watch",
      "isBackground": true,
      "problemMatcher": "$esbuild-watch",
      "presentation": { "group": "watch", "reveal": "never" }
    },
    {
      "label": "watch:tsc",
      "type": "shell",
      "command": "pnpm exec tsc -p tsconfig.json --watch --noEmit",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": { "group": "watch", "reveal": "never" }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm run build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "compile-tests",
      "type": "shell",
      "command": "pnpm run pretest:integration",
      "problemMatcher": []
    }
  ]
}
